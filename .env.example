# Copy to .env and fill values.

# Agent identity
AGENT_NAME=gardengnome
OPENCLAW_MODEL=openrouter/stepfun/step-3.5-flash:free

# Optional: timezone for scheduled jobs
TIMEZONE=Europe/Copenhagen

# Database (PostgreSQL) — optional during install; local or remote server
# Example: postgresql://gardengnome:secret@localhost:5432/gardengnome?sslmode=prefer
# You can export GARDENGNOME_DATABASE_URL before running install.sh, answer the prompt, or edit after setup.
GARDENGNOME_DATABASE_URL=
# After URL is set: installer tests connectivity. Set to 1 to apply core migrations in db/postgres/*.sql (requires psql).
# Skips files with seed/example in the name and skips migrations already listed in schema_migrations.
GARDENGNOME_DB_APPLY_SCHEMA=0
# 1 = after migrations, also run db/postgres/seeds/*.sql (optional example rows — off by default)
GARDENGNOME_DB_APPLY_SEEDS=0
# 1 = skip all DB steps (no prompt expectation; no connectivity test)
GARDENGNOME_DB_SKIP_INIT=0

# Constrained-LLM helpers (scripts/constrained_llm_pipeline.py — optional)
# Vectors default to Qdrant; PostgreSQL holds structured rows (see db/postgres/002_openclaw_constrained_llm.sql).
# For an all-in-Postgres option, add pgvector + an embedding column in a custom migration (see comments in 002).
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=qwen2.5:7b
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION_SEMANTIC_CACHE=openclaw_semantic_cache
QDRANT_COLLECTION_RAG_CHUNKS=openclaw_rag_chunks
SEMANTIC_CACHE_MIN_SCORE=0.92
RAG_MIN_SCORE=0.88

# Placeholder provider keys (feature phase)
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
TELEGRAM_BOT_TOKEN=
