# Copy to config/garden.env and fill in (config/garden.env is gitignored).
# Same PostgreSQL URL as GARDENGNOME_DATABASE_URL in the workspace .env at the root.
GARDEN_DB_URL=postgresql://user:pass@localhost:5432/gardengnome?sslmode=prefer

# Weather (Open-Meteo — no API key). Override base URLs if self-hosting the API.
OPEN_METEO_URL=https://api.open-meteo.com
OPEN_METEO_ARCHIVE_URL=https://archive-api.open-meteo.com

GARDEN_LAT=55.6761
GARDEN_LON=12.5683
GARDEN_TIMEZONE=Europe/Copenhagen

# Optional: alerts / briefing (scripts may send messages if set)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Thresholds for derived fields (defaults match weather_parse.py)
FROST_THRESHOLD_C=2.0
SPRAY_WIND_MAX_MS=5.0
SPRAY_CLOUD_MAX_PCT=70
OUTDOOR_TEMP_MIN_C=5.0
OUTDOOR_WIND_MAX_MS=8.0
HEAVY_RAIN_MM=15.0
HEAT_THRESHOLD_C=28.0
HIGH_WIND_GUST_MS=12.0
HOURLY_SPRAY_CONSECUTIVE=3

# Daily briefing (scripts/daily_briefing.sh → local Ollama)
OLLAMA_HOST=http://127.0.0.1:11434
BRIEFING_MODEL=qwen2.5:7b
DAILY_BRIEFING_PATH=
# If empty, defaults to $GARDENGNOME_ROOT/briefings/daily.md inside the script
